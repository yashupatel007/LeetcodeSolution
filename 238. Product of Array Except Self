class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n=nums.size();
        vector<int>ans(n,1);
        //calculate left product
        for(int i=1;i<n;i++)
        {
            ans[i]=ans[i-1]*nums[i-1];
        }
        //move right from backward nums and multiply with ans
        int right=1;
        for(int j=n-2;j>=0;j--)
        {
            right=right*nums[j+1];
            ans[j]=ans[j]*right;
        }
        return ans;
    }
};

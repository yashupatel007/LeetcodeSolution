/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
 class Box
 {
    public:
    bool BST;
    long long sum;
    int min,max;

    Box()
    {
        BST=1;
        sum=0;
        min=INT_MAX;
        max=INT_MIN;
    }
 };
class Solution {
public:
    Box* find(TreeNode* root,long long& total_sum)
    {
        //root doesn't exist
        if(!root)
        {
            return new Box();//return the construnctor
        }
        //root exist
        Box* left_head=find(root->left,total_sum);// move left & get details
        Box* right_head=find(root->right,total_sum);// move right & get details

        if(left_head->BST && right_head->BST && left_head->max<root->val && right_head->min>root->val)
        // left-BST=1 and right-BST=1 and root value > left and root value < right
        {
            Box* head=new Box();//call constructor to edit details
            head->sum=root->val+ left_head->sum + right_head->sum;// find the total sum
            head->min=min(left_head->min,root->val);// find min of subtree
            head->max=max(right_head->max,root->val);// max of subtree
            total_sum=max(total_sum,head->sum);//update final sum
            return head;
        }
        else// return either left or right 
        {
            left_head->BST=0;
            return left_head;
        }
    }
    int maxSumBST(TreeNode* root) {
        long long total_sum=0;
        find(root,total_sum);
        return (int)total_sum;
    }
};

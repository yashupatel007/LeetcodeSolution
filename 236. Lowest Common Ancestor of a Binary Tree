/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode(int x) : val(x), left(NULL), right(NULL) {}
 * };
 */
class Solution {
public:
    
    TreeNode* lowestCommonAncestor(TreeNode* root, TreeNode* p, TreeNode* q) {
        if(!root)
            return NULL;
        if(root->val==p->val)
            return p;
        if(root->val==q->val)
            return q;
        TreeNode* l=lowestCommonAncestor(root->left,p,q);
        TreeNode* r=lowestCommonAncestor(root->right,p,q);
        // both NULL
        if(!l && !r)
            return NULL;
        //one Node
        else if(!l && r)// right exist
            return r;
        else if(l && !r)//left exist
            return l;
        //both Node
        else
            return root;


    }
};

/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* reverse(ListNode* curr,ListNode* stop)
    {
        ListNode* prev=stop;
        ListNode* fut=NULL;
        while(curr!=stop)
        {
            fut=curr->next;
            curr->next=prev;
            prev=curr;
            curr=fut;
        }
        return prev;
    }
    ListNode* reverseBetween(ListNode* head, int left, int right) {
        if(head->next==NULL || left==right)
            return head;
        //point the left and right
        ListNode* l=head;
        ListNode* r=head;
        ListNode* curr=NULL;
        while(--left)
        {
            curr=l;
            l=l->next;
        }
        while(--right)
        {
            r=r->next;
        }
        if(curr==NULL){
            return reverse(l,r->next);
        }
        else{
       curr->next=reverse(l,r->next);
        return head;
        }
    }
};

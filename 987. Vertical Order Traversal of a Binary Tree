/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    vector<vector<int>> verticalTraversal(TreeNode* root) {
        vector<vector<int>>ans;
        if(!root)
            return ans;
        //[height distance --> [level],{sorted node value}]
        map<int,map<int,multiset<int>>>mp;
        queue<pair<TreeNode*,pair<int,int>>>q;
        q.push({root,{0,0}});

        while(!q.empty())
        {
            auto details=q.front();
            q.pop();

            TreeNode* temp=details.first;
            int HD=details.second.first;
            int level=details.second.second;

            mp[HD][level].insert(temp->val);// N
            if(temp->left) q.push({temp->left,{HD-1,level+1}});// L
            if(temp->right) q.push({temp->right,{HD+1,level+1}});// R
        }
        //now put value in 2D vector
        for(auto i:mp)
        {
            vector<int>res;
            for(auto j:i.second)
            {
                res.insert(res.end(),j.second.begin(),j.second.end());//copy entire set in one step
            }
            ans.push_back(res);
        }
        return ans;
    }
};

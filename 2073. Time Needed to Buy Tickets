class Solution {
public:
    int timeRequiredToBuy(vector<int>& tickets, int k) {
        int n=tickets.size();
        int time=0;
        queue<int>q;
        for(int i=0;i<n;i++)
        {
            q.push(i);
        }
        int index=0;
        while(!tickets[k]==0)
        {
           int i= q.front();
           q.pop();
           if(!tickets[i]==0)
           {
            tickets[i]--;
            time++;
            q.push(i);
           }
        }
        return time;
    }
};

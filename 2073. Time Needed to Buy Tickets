class Solution {
public:
    int timeRequiredToBuy(vector<int>& tickets, int k) {
        int n=tickets.size();
        int time=0;
        queue<int>q;
        for(int i=0;i<n;i++)
        {
            q.push(i);
        }
        int index=0;
        while(!tickets[k]==0)
        {
           int i= q.front();
           q.pop();
           if(!tickets[i]==0)
           {
            tickets[i]--;
            time++;
            q.push(i);
           }
        }
        return time;
    }
};
//2nd approach

class Solution {
public:
    int timeRequiredToBuy(vector<int>& tickets, int k) {
        int n=tickets.size();
        int time=0;
        for(int i=0;i<k;i++)//for Left Side
        {
            time+=min(tickets[k],tickets[i]);
        }
        //for right side
        for(int j=n-1;j>k;j--)
        {
            time+=min(tickets[k]-1,tickets[j]);
        }
        return time+tickets[k];
    }
};

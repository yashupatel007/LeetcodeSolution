class Solution {
public:
    int lastStoneWeight(vector<int>& stones) {
        priority_queue<int>p(stones.begin(),stones.end());

        while(p.size()>1)
        {
            int f1=p.top();
            p.pop();
            int f2=p.top();
            p.pop();

            int res=abs(f1-f2);
            if(res!=0)  p.push(res);
        }
        if(!p.empty())
            return p.top();
        return 0;
    }
};

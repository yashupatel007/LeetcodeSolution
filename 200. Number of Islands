class Solution {
public:
    int row;
    int col;
    int r[4]={-1,1,0,0};
    int c[4]={0,0,-1,1};

    bool valid(int i,int j)
    {
        return i>=0 && i<row && j>=0 && j<col;
    }
    int numIslands(vector<vector<char>>& grid) {
        row=grid.size();
        col=grid[0].size();
        queue<pair<int,int>>q;
        int count=0;

        for(int i=0;i<row;i++)
        {
            for(int j=0;j<col;j++)
            {
                if(grid[i][j]=='1')
                {
                    count++;
                    grid[i][j]='0';
                    q.push({i,j});

                    while(!q.empty())
                    {
                        int r1=q.front().first;
                        int c1=q.front().second;
                        q.pop();

                        for(int k=0;k<4;k++)
                        {
                            if(valid(r1+r[k],c1+c[k]) && grid[r1+r[k]][c1+c[k]]=='1')
                            {
                                grid[r1+r[k]][c1+c[k]]='0';
                                q.push({r1+r[k],c1+c[k]});
                            }
                        }
                    }
                }
            }
        }
        return count;
    }
};

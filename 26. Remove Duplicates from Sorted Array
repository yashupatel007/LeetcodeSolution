class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n=nums.size();
        int count=0;
        int target=0;
        for(int i=0;i<n;i++){
            if(i==0 || nums[i]!=nums[i-1])
                count=1;
            else
                count++;

            if(count<=1)
            {
                nums[target]=nums[i];
                target++;
            }
        }
        return target;
    }
};

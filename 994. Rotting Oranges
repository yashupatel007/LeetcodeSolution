class Solution {
public:
    int r[4]={-1,1,0,0};
    int c[4]={0,0,-1,1};
    int row;
    int col;

    bool valid(int i,int j) 
    {
        return i>=0 && i<row && j>=0 && j<col;
    }

    int orangesRotting(vector<vector<int>>& grid) {
        row=grid.size();
        col=grid[0].size();
        queue<pair<int,int>>q;

        //push all 2 in q
        for(int i=0;i<row;i++)
            for(int j=0;j<col;j++)
                if(grid[i][j]==2)
                    q.push({i,j});

        int timer=0;
        while(!q.empty())
        {
            timer++; // increase timer after certain interval
            int interval=q.size();
            
            while(interval--)//spread untill interval
            {
                int i=q.front().first;
                int j=q.front().second;
                q.pop();

                for(int k=0;k<4;k++)// check in all 4 direction
                {
                    if(valid(i+r[k],j+c[k]) && grid[i+r[k]][j+c[k]]==1)// if inside grid and is 1
                    {
                        grid[i+r[k]][j+c[k]]=2; // make 1->2 & push in q
                        q.push({i+r[k],j+c[k]});
                    }
                }

            }
        }
        // check if there is 1 left
        for(int i=0;i<row;i++)
            for(int j=0;j<col;j++)
                if(grid[i][j]==1)
                    return -1;

        // if timer=0 -> return 0 not -1
        //we done timer-1 to remove the last check cond^n
        return !timer ? 0 : timer-1;
    }
};

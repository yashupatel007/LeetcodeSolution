class Solution {
public:
    int X[8]={0,0,1,1,1,-1,-1,-1};
    int Y[8]={1,-1,1,0,-1,1,0,-1};

    bool valid_neighbour(int currX,int currY,int row,int col){
        return (currX>=0 && currX<row && currY>=0 && currY<col);
    }

    void gameOfLife(vector<vector<int>>& board) {
        int row=board.size();
        int col=board[0].size();

        //traverse the matrix
        for(int r=0;r<row;r++)
        {
            for(int c=0;c<col;c++)
            {
                int live_count=0;
                //check how many neighbour is live
                for(int i=0;i<8;i++)
                {
                    //neighbour of board[r][c]
                    int currX=r+X[i];
                    int currY=c+Y[i];
                    //check if it is inside the matrix & is live neighbour
                    if(valid_neighbour(currX,currY,row,col) && abs(board[currX][currY])==1)
                        live_count++;
                }
                //check the given  conditions
                if(board[r][c]==1 && (live_count<2 || live_count>3))
                    board[r][c]=-1;//1->0

                if(board[r][c]==0 && live_count==3)
                    board[r][c]=2;//0->1
            }
        }
                //now change in our matrix
                for(int r=0;r<row;r++)
                {
                    for(int c=0;c<col;c++)
                    {
                        if(board[r][c]<=0)//0 se kam means 0
                            board[r][c]=0;
                        else
                            board[r][c]=1;//0 se uper means 1
                    }
                }
    }
};

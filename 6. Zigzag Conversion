// 1st approach 

class Solution {
public:
    string convert(string s, int numRows) {
        if(numRows==1)
            return s;
        int n=s.size();
        vector<string>rows(numRows);
        int direction=1;
        int current_row=-1;
        for(int i=0;i<n;i++)
        {
            if(current_row==0)
                direction=1;
            else if(current_row==numRows-1)
                direction=-1;
            current_row+=direction;
            rows[current_row].push_back(s[i]);
            
        }
        string ans="";
        for(string x:rows)
            ans+=x;
        return ans;
    }
};

// 2nd efficient approach

class Solution {
public:
    string convert(string s, int numRows) {
        if(numRows==1)
            return s;
        int n=s.size();
        int repeat=2*numRows-2;
        string ans="";
        
        for(int i=0;i<numRows;i++)
        {
            for(int j=i;j<n;j+=repeat)
            {
                ans+=s[j];
                int diagonal_index = j + repeat - ( 2 * i );
                if((i!=0 && i!=numRows-1) && diagonal_index<n)// check pillar
                    ans+=s[diagonal_index];
            }
        }
        return ans;
    }
};

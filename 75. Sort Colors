class Solution {
public:
    void sortColors(vector<int>& nums) {
        int n=nums.size();
        int s0=0,s1=0,s2=0;
        for(int i=0;i<n;i++)
        {
            if(nums[i]==0)
                s0++;
            else if(nums[i]==1)
                s1++;
            else
                s2++;
            
        }
        int index=0;
        while(s0--)
        {
            nums[index]=0;
            index++;
        }
      
        while(s1--)
        {
            nums[index]=1;
            index++;
        }
        
        while(s2--)
        {
            nums[index]=2;
            index++;
        }
        for(int i=0;i<n;i++)
            cout<<nums[i]<<" ";
    }
};

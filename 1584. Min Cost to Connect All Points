class Solution {
public:
    int minCostConnectPoints(vector<vector<int>>& points) {
        int V=points.size();
        priority_queue<pair<int,int>,vector<pair<int,int>>,greater<pair<int,int>>>p;
        p.push({0,0});//cost & node_index
        vector<bool>visited(V,0);
        int total_connected=0;// count the no. of nodes connected
        int cost=0;

        while(!p.empty() && total_connected!=V)
        {
            int dist=p.top().first;
            int node=p.top().second;
            p.pop();

            if(visited[node])
                continue;
            
            visited[node]=1;
            cost+=dist;
            //calculate dist
            int x=node;
            for(int y=0;y<V;y++)
            {
                if(!visited[y])
                {
                    int distance= abs(points[x][0]-points[y][0]) + abs(points[x][1]-points[y][1]);
                    p.push({distance,y});
                }
            }
        }
        return cost;
    }
};

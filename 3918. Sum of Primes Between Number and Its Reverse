class Solution {
public:
    bool prime(int n)
    {
        if(n<=1)
            return false;
        for(int i=2;i*i<=n;i++ )
            {
                if(n%i==0)
                    return false;
            }
        return true;
    }
    int sumOfPrimesInRange(int n) {
        long long sum=0;
      
        string s= to_string(n);
        reverse(s.begin(),s.end());
        int temp=stoi(s);
        int mini=min(n,temp);
        int maxi=max(n,temp);

        for(int i=mini;i<=maxi;i++)
            {
                if(prime(i))
                    sum+=i;
                
            }
        return sum;
    }
};



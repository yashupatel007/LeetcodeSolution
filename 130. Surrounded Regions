class Solution {
public:
    int row;
    int col;
    int r[4]={-1,1,0,0};
    int c[4]={0,0,-1,1};

    bool valid(int i,int j)
    {
        return i<row && i>=0 && j>=0 && j<col;
    }

    void solve(vector<vector<char>>& board) {
        row=board.size();
        col=board[0].size();
        queue<pair<int,int>>q;

        // first row
        for(int j=0;j<col;j++)
        {
            if(board[0][j]=='O')
            {
                board[0][j]='T';
                q.push({0,j});
            }
        }
        //last row
        for(int j=0;j<col;j++)
        {
            if(board[row-1][j]=='O')
            {
                board[row-1][j]='T';
                q.push({row-1,j});
            }
        }
        // first col
        for(int i=0;i<row;i++)
        {
            if(board[i][0]=='O')
            {
                board[i][0]='T';
                q.push({i,0});
            }
        }
        // last col
         for(int i=0;i<row;i++)
        {
            if(board[i][col-1]=='O')
            {
                board[i][col-1]='T';
                q.push({i,col-1});
            }
        }

        //spread all corner O -> T as they are not part
        while(!q.empty())
        {
            int i=q.front().first;
            int j=q.front().second;
            q.pop();

            for(int k=0;k<4;k++)
            {
                if(valid(i+r[k],j+c[k]) && board[i+r[k]][j+c[k]]=='O')
                {
                    board[i+r[k]][j+c[k]]='T';
                    q.push({i+r[k],j+c[k]});
                }
            }
        }
        // replace all T-> O & O-> X
        for(int i=0;i<row;i++)
            for(int j=0;j<col;j++)
                if(board[i][j]=='T')
                    board[i][j]='O';
                else if(board[i][j]=='O')
                    board[i][j]='X';
    }
};

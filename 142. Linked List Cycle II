/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
 */
class Solution {
public:
    ListNode *detectCycle(ListNode *head) {
        if(!head || !head->next)
            return NULL;
        //check for cycle
        ListNode* slow=head;
        ListNode* fast=head;
        while(fast!=NULL && fast->next!=NULL)
        {
            slow=slow->next;
            fast=fast->next->next;
            if(slow==fast)//loop found
                break;
        }
        if(fast==NULL || fast->next==NULL)
            return NULL;
        slow=head;
        while(slow!=fast)//find the loop start node
        {
            slow=slow->next;
            fast=fast->next;
        }
        return slow;
    }
};

class Solution {
public:
    int singleNumber(vector<int>& nums) {
        int ans=0;
        
        for(int k=0;k<32;k++)
        {
            int temp=(1<<k); // for checking which bit is 0 or 1
            int zero_count=0;
            int ones_count=0;

            for(int x:nums)
            {
                if((x & temp) ==0) // count which bit is 0 & 1
                    zero_count++;
                else
                    ones_count++;
            }
            if(ones_count % 3==1)
                ans=(ans | temp);
        }
        return ans;
    }
};

class Solution {
public:
    int minCostClimbingStairs(vector<int>& cost) {
        int n=cost.size();

        int first=0;//dp[n-1]
        int second=0;// dp[n-2]
        int currCost=0;

        for(int i=2;i<=n;i++)
        {
            currCost=min(first+cost[i-1],second+cost[i-2]);
            second=first;
            first=currCost;
        }
        return currCost;
    }
};

class Solution {
public:
      void find(int row,int n,int& count, vector<bool>& col,vector<bool>& leftDiagonal, vector<bool>& rightDiagonal)
    
    {
        //base case
        if(row==n)  //checked every cell
        {
            count++;
            return;
        }

        // find place to put n queens
        for(int j=0;j<n;j++)
        {
            if(col[j]==0 && leftDiagonal[(n-1)+j-row]==0 && rightDiagonal[row+j]==0)
            {
                col[j]=1;
                leftDiagonal[(n-1)+j-row]=1;
                rightDiagonal[row+j]=1;

               find(row+1,n,count,col,leftDiagonal,rightDiagonal);

                col[j]=0;
                leftDiagonal[(n-1)+j-row]=0;
                rightDiagonal[row+j]=0;
            }
        }
    }
    int totalNQueens(int n) {
        int count=0;
        vector<bool>col(n,0);
        vector<bool>leftDiagonal(2*n-1,0);
        vector<bool>rightDiagonal(2*n-1,0);


        find(0,n,count,col,leftDiagonal,rightDiagonal);

        return count;
    }
};

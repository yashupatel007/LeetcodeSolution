class Solution {
public:
    int firstStableIndex(vector<int>& nums, int k) {
        int n=nums.size();
        int ans=INT_MAX;
       if(n==0) return -1;
        vector<pair<int,int>>l(n);
        int cmax=nums[0];
        for(int i=0;i<n;i++)
            {
                cmax=max(cmax,nums[i]);
                l[i].first=cmax;
            }
        int cmin=nums[n-1];
        for(int i=n-1;i>=0;i--)
            {
                cmin=min(cmin,nums[i]);
                l[i].second=cmin;
            }
        for(int i=0;i<n;i++)
            {
                if(l[i].first-l[i].second<=k)
                {
                    return i;
                }
            }
        return -1;
    }
};

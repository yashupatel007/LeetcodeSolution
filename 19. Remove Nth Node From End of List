/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n) {
        //count the total node in LL
        int count=0;
        ListNode *curr=head;
        while(curr!=NULL)
        {
            count++;
            curr=curr->next;
        }
        count=count-n;//node to be deleted
        ListNode *prev=NULL;
        curr=head;//reset curr to head
        if(count==0)//to remove 1st node
        {
            head=head->next;
            delete curr;
        }
        else //remove another node except 1st
        {
        while(count!=0)
        {
            prev=curr;
            curr=curr->next;
            count--;
        }
        prev->next=curr->next;
        delete curr;
        }
        return head;
    }
};

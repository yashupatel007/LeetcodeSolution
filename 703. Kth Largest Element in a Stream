class KthLargest {
public:
    priority_queue<int,vector<int>,greater<int>>p;
    int K;
    KthLargest(int k, vector<int>& nums) {
        K=k;
        if(nums.size()>0 && k<=nums.size())
        {
        for(int i=0;i<k;i++)
            p.push(nums[i]);
        for(int i=k;i<nums.size();i++)
        {
            if(nums[i]>p.top())
            {
                p.pop();
                p.push(nums[i]);
            }
        }
        }
        if(k>nums.size())
        {
            for(int i=0;i<k-1;i++)
                p.push(nums[i]);
        }
    }
    
    int add(int val) {
        if(!p.empty()&& K<=p.size() && val>p.top())
        {
        p.pop();
        p.push(val);
        }

         if(p.empty() || K>p.size())
            p.push(val);
       
        return p.top();
    }
};


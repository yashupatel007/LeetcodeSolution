class Solution {
public:
    bool backspaceCompare(string s, string t) {
        int n=s.size();
        int m=t.size();
        stack<char>s1;
        stack<char>s2;
        for(int i=0;i<n;i++)
        {
            if(s[i]=='#')
            {
                if(!s1.empty())
                    s1.pop();
            }
            else
                s1.push(s[i]);
        }
        for(int j=0;j<m;j++)
        {
            if(t[j]=='#')
            {
                if(!s2.empty())
                    s2.pop();
            }
            else
                s2.push(t[j]);
        }
        string temp1="";
        string temp2="";
        while(!s1.empty())
        {
            temp1+=s1.top();
            s1.pop();
        }
        while(!s2.empty())
        {
            temp2+=s2.top();
            s2.pop();
        }
        return temp1==temp2;
    }
};

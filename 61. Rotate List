/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        if(k==0 || head==NULL)//for empty LL or nothing to rotate
            return head;
        ListNode *temp=head;
        int count=0;
        while(temp->next!=NULL)//count the no. of nodes
        {
            count++;
            temp=temp->next;
        }
        count++;
        k=k%count;
        if(count==k || k==0)//nothing to rotate
            return head;
        count-=k;
        ListNode *curr=head;
        ListNode *prev=NULL;
        while(count!=0)
        {
            prev=curr;
            curr=curr->next;
            count--;
        }
        prev->next=NULL;
        temp->next=head;
        return curr;
    }
};

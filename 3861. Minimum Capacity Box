class Solution {
public:
    int minimumIndex(vector<int>& capacity, int itemSize) {
        int n=capacity.size();
        int minindex=-1;
        int minvalue=INT_MAX;
        for(int i=0;i<n;i++)
        {
            if(capacity[i]>=itemSize)
            {
               if(capacity[i]<minvalue)
               {
                minindex=i;
                minvalue=capacity[i];
               }
            }
        }
        return minindex;
    }
};

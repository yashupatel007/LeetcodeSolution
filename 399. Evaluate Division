class Solution {
public:
    vector<double> calcEquation(vector<vector<string>>& equations, vector<double>& values, vector<vector<string>>& queries) {
        int count=0;// for string "a"-0 etc.
        unordered_map<string,int>mp;
        for(int i=0;i<equations.size();i++)
        {
            string u=equations[i][0];
            string v=equations[i][1];
            // check if u || v present in mp or not

            if(!mp.count(u))
            {
                mp[u]=count;
                count++;
            }
            if(!mp.count(v))
            {
                mp[v]=count;
                count++;
            }
        }
        int n=count; // count give the total no. of variable present
        vector<vector<double>>grid(n,vector<double>(n,-1.0));
        // mark the weights in grid
        for(int i=0;i<equations.size();i++)
        {
            int u=mp[equations[i][0]];
            int v=mp[equations[i][1]];

            grid[u][v]=values[i];// a->b
            grid[v][u]=1.0/values[i];// b->a
        }
        int V=equations.size();
        //use floyd warshell to fill rest
        for(int k=0;k<count;k++)
        {
            grid[k][k]=1.0;
            for(int i=0;i<count;i++)
            {
                for(int j=0;j<count;j++)
                {
                    if(grid[i][k]!=-1.0 && grid[k][j]!=-1.0)
                    {
                    grid[i][j]=grid[i][k]*grid[k][j];
                    grid[j][i]=1.0/grid[i][j];
                    }
                }
            }
        }

        vector<double>ans;
        for(vector<string>& q: queries)
        {
            if(!mp.count(q[0]) || !mp.count(q[1]))
            {
                ans.push_back(-1.0);
                continue;
            }
            int i=mp[q[0]];
            int j=mp[q[1]];
            double value=grid[i][j];

            ans.push_back(value);
        }
        return ans;

    }
};

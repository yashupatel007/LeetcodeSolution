/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
     ListNode* merge(ListNode* head1,ListNode* head2)
    {
        ListNode* head=new ListNode(0,NULL);
        ListNode* tail=head;
        while(head1 && head2)
        {
            if(head1->val<=head2->val)
            {
                tail->next=head1;
                head1=head1->next;
                tail=tail->next;
                tail->next=NULL;
            }
            else
            {
                tail->next=head2;
                head2=head2->next;
                tail=tail->next;
                tail->next=NULL;
            }
        }
        if(head1)
            tail->next=head1;
        else
            tail->next=head2;
        return head->next;
    }
    ListNode* sortList(ListNode* head) {
        if(!head || !head->next)
            return head;
        ListNode* prev=NULL;
        ListNode* slow=head;
        ListNode* fast=head;
        while(fast && fast->next)
        {
            prev=slow;
            slow=slow->next;
            fast=fast->next->next;
        }
        prev->next=NULL;//disconnect u can use slow->next
        ListNode* l1=sortList(head);//left
        ListNode* l2=sortList(slow);//right
        return merge(l1,l2);//merge and return
    }
};

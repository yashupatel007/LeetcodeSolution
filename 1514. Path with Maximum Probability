class Solution {
public:
    double maxProbability(int n, vector<vector<int>>& edges, vector<double>& succProb, int start_node, int end_node) {
        vector<vector<pair<int,double>>>adj(n);
        // apply inver Djisktra algo
        // make adj matrix
        for(int i=0;i<edges.size();i++)
        {
            int u=edges[i][0];
            int v=edges[i][1];
            double w=succProb[i];
            adj[u].push_back({v,w});
            adj[v].push_back({u,w});
        }

        priority_queue<pair<double,int>>p;
        p.push({1.00,start_node});
        vector<bool>explore(n,0);
        vector<double>prob(n,0.0);
        prob[start_node]=1.00;

        while(!p.empty())
        {
            int node=p.top().second;
            p.pop();

            if(!explore[node])
            {
                explore[node]=1;
                
                for(int j=0;j<adj[node].size();j++)
                {
                    int neigh=adj[node][j].first;
                    double weight=adj[node][j].second;

                    if(!explore[neigh] && prob[node]*weight > prob[neigh])
                    {
                        prob[neigh]=prob[node]*weight;
                        p.push({prob[neigh],neigh});
                    }
                }
            }
        }
        return prob[end_node];
    }
};

/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    TreeNode* deleteNode(TreeNode* root, int key) {
        if(!root)
            return NULL;
        
        if(root->val>key)//move left
        {
            root->left=deleteNode(root->left,key);
            return root;
        }
        else if(root->val<key)//move right
        {
            root->right=deleteNode(root->right,key);
            return root;
        }
        else  //if key==root->val
        {
            //left node
            if(!root->left && !root->right)
            {
                delete root;
                return NULL;
            }
            // 1 child exist
            else if(!root->left) //only right child exist
            {
                TreeNode* temp=root->right;
                delete root;
                return temp;
            }
            else if(!root->right)// only left child exist
            {
                TreeNode* temp=root->left;
                delete root;
                return temp;
            }
            // 2 child exist
            else
            {
                TreeNode* parent=root;
                TreeNode* child=root->left;
                //move parent ke left  ke right most
                while(child->right)
                {
                    parent=child;
                    child=child->right;
                }
                if(root!=parent)//child->left ko parent ke right me dalo
                {// child ko root ki jagah put karo
                    parent->right=child->left;
                    child->left=root->left;
                    child->right=root->right;
                    delete root;
                    return child;
                }
                else  //parent==root
                {
                    child->right=parent->right;
                    delete root;
                    return child;
                }
            }
        }
    }
};

class Solution {
public:
    int numSubarraysWithSum(vector<int>& nums, int goal) {
        int n=nums.size();
        int left=0;
        int right=0;
        int sum=0;
        int count=0;
        int prefix_0=0;

        while(right<n)
        {
            sum+=nums[right];

            while(left<right && sum>goal)
            {
                sum-=nums[left];
                left++;
                prefix_0=0;
            }

            while(left<right && nums[left]==0)
            {
                left++;
                prefix_0++;
            }
            if(sum==goal)
                count+=(1+prefix_0);
            right++;
        }
        return count;
    }
};

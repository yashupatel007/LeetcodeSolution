class Solution {
public:
    long long pickGifts(vector<int>& gifts, int k) {
        priority_queue<int>p(gifts.begin(),gifts.end());

        while(k--)
        {
            int temp=p.top();
            p.pop();
            p.push(floor(sqrt(temp)));
        }
        long long ans=0;
        while(!p.empty())
        {
            ans+=p.top();
            p.pop();
        }
        return ans;
    }
};

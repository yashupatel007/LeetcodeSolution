class Solution {
public:
    int minimumTime(int n, vector<vector<int>>& relations, vector<int>& time) {
        vector<vector<int>>adj(n);
        vector<int>indeg(n,0);
        //make adj mat. & indeg
        for(int i=0;i<relations.size();i++)
        {
            adj[relations[i][0]-1].push_back(relations[i][1]-1);// -1 for 0 indexing
            indeg[relations[i][1]-1]++;
        }
        // find indeg 0 and push in q
        queue<int>q;
        for(int i=0;i<n;i++)
        {
            if(!indeg[i])
                q.push(i);
        }

        //max time to complete prev. course
        vector<int>courseTime(n,0);

        while(!q.empty())
        {
            int node=q.front();
            q.pop();

            for(int j=0;j<adj[node].size();j++)
            {
                indeg[adj[node][j]]--;
                if(!indeg[adj[node][j]])
                    q.push(adj[node][j]);
                // max time to complete prev course + present time
                courseTime[adj[node][j]]=max(courseTime[adj[node][j]],courseTime[node]+time[node]);
            }
        }
        int ans=0;
        for(int i=0;i<n;i++)
        {
            ans=max(ans,courseTime[i]+time[i]);
        }
        return ans;
    }
};

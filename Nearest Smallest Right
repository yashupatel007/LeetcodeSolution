        //find the NSR index
        vector<int>NSR(n,0);
        stack<int>st;
        for(int i=n-1;i>=0;i--)
        {
            while(!st.empty() && heights[i]<=heights[st.top()])
            {
                st.pop();
            }
            if(!st.empty())
            {
                NSR[i]=st.top();
            }
            st.push(i);
        }
        while(!st.empty())
        {
            NSR[st.top()]=n;
            st.pop();
        }

/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
   TreeNode* Tree(vector<int>& preorder,unordered_map<int,int>& inMap,int inStart,int inEnd,int& preIndex)
   {
    if(inStart>inEnd)
        return NULL;
    
    TreeNode* root=new TreeNode(preorder[preIndex]);//build root
    int pos=inMap[preorder[preIndex]];
    preIndex++;

    root->left=Tree(preorder,inMap,inStart,pos-1,preIndex);//for left subtree
    root->right=Tree(preorder,inMap,pos+1,inEnd,preIndex);//for right subtree
    return root;
   }
    TreeNode* buildTree(vector<int>& preorder, vector<int>& inorder) {
         unordered_map<int,int>inMap;
         for(int i=0;i<inorder.size();i++)
         {
            inMap[inorder[i]]=i;
         }
        int preIndex=0;
        return Tree(preorder,inMap,0,inorder.size()-1,preIndex);
    }
    
};

class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& nums1, vector<int>& nums2) {
        int n=nums1.size();
        int m=nums2.size();
        stack<int>st;
        unordered_map<int,int>mp;
        for(int i=m-1;i>=0;i--)//store the greater next into the map
        {
            while(!st.empty() && nums2[i]>st.top())
                st.pop();

            if(!st.empty())
                mp[nums2[i]]=st.top();

            st.push(nums2[i]);
        }
        vector<int>ans(n,-1);
        for(int j=0;j<n;j++)//copy the nums1 only element value to ans 
        {
            if(mp.contains(nums1[j]))
                ans[j]=mp[nums1[j]];
        }
        return ans;
    }
};

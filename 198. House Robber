class Solution {
public:
    int rob(vector<int>& nums) {
        int n=nums.size();

        if(n==1)    return nums[0];
        if(n==2)    return max(nums[0],nums[1]);

        int first=max(nums[0],nums[1]);
        int second=nums[0];
        int maxi=0;
        for(int i=2;i<n;i++)
        {
            maxi=max(nums[i]+second,first);
            second=first;
            first=maxi;
        }
        return maxi;
    }
};

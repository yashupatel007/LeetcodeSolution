class Solution {
public:
    long long countSubarrays(vector<int>& nums, long long k) {
        int n=nums.size();
        int left=0;
        int right=0;
        long long score=0;
        long long count=0;
        long long sum=0;

        while(right<n)
        {
            sum+=nums[right];
            score=sum*(right-left+1);
            while(left<=right && score>=k)
            {
                sum-=nums[left];
                left++;
                score=sum*(right-left+1);
            }
            count+=right-left+1;
            right++;
        }
        return count;
    }
};

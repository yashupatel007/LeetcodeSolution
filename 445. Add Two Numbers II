/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* rev(ListNode* curr,ListNode* prev)
    {
        ListNode* fut=NULL;
        while(curr)
        {
        fut=curr->next;
        curr->next=prev;
        prev=curr;
        curr=fut;
        }
        return prev;
    }
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        ListNode* h1=rev(l1,NULL);
        ListNode* h2=rev(l2,NULL);
        ListNode* dummy=new ListNode(0,NULL);
        ListNode* tail=dummy;
        int carry=0;
        while(h1 && h2)
        {
            int sum=h1->val + h2->val + carry;
            tail->next=new ListNode(sum%10);
            carry=sum/10;
            h1=h1->next;
            h2=h2->next;
            tail=tail->next;
        }
        //if any h1 or h2 left
        while(h1)
        {
            int sum=h1->val + carry;
            tail->next=new ListNode(sum%10);
            carry=sum/10;
            h1=h1->next;
            tail=tail->next;
        }
        while(h2)
        {
            int sum=h2->val + carry;
            tail->next=new ListNode(sum%10);
            carry=sum/10;
            h2=h2->next;
            tail=tail->next;
        }
        //if carry left
        while(carry)
        {
            tail->next=new ListNode(carry%10);
            carry/=10;
           
        }
        ListNode* h3=rev(dummy->next,NULL);
        return h3;
    }
};

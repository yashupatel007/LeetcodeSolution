/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    bool dfs(TreeNode *node)
    {
        if(node==NULL)//base case
            return false;
        
        bool left=dfs(node->left);//move ekdam left
        bool right=dfs(node->right);//move ekdam right

        if(left==false)//if left is NULL
            node->left=NULL;//remove node
        if(right==false)//if right is NULL
            node->right=NULL;//remove
        
        if(node->val==1 || left==true || right==true)//check anyone is true or not
            return true;//return to parent
        else 
            return false;//return to parent
    }
    TreeNode* pruneTree(TreeNode* root) {
        if(dfs(root))//if root present
            return root;
        
        return NULL;//if no root is present
    }
};

class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int n=prices.size();
        if(n==1)
            return 0;
        int left=0;
        int right=1;
        int maxi=INT_MIN;
        while(right<n)
        {
            if(prices[left]<prices[right])
            {
                maxi=max(maxi,prices[right]-prices[left]);
                right++;
            }
            else
            {
                left=right;
                right++;
            }
        }
        if(maxi==INT_MIN)
            return 0;
        return maxi;
    }
};

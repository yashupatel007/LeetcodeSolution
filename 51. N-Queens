class Solution {
public:
    void find(int row,int n,vector<string>& board,vector<vector<string>>& ans, vector<bool>& col,
               vector<bool>& leftDiagonal, vector<bool>& rightDiagonal)
    
    {
        //base case
        if(row==n)  //checked every cell
        {
            ans.push_back(board);
            return;
        }

        // find place to put n queens
        for(int j=0;j<n;j++)
        {
            if(col[j]==0 && leftDiagonal[(n-1)+j-row]==0 && rightDiagonal[row+j]==0)
            {
                board[row][j]='Q';
                col[j]=1;
                leftDiagonal[(n-1)+j-row]=1;
                rightDiagonal[row+j]=1;

               find(row+1,n,board,ans,col,leftDiagonal,rightDiagonal);

                 board[row][j]='.';
                col[j]=0;
                leftDiagonal[(n-1)+j-row]=0;
                rightDiagonal[row+j]=0;
            }
        }
    }
    vector<vector<string>> solveNQueens(int n) {
        vector<string>board(n,string(n,'.'));   // make every cell -> '.'
        vector<vector<string>>ans;
        vector<bool>col(n,0);
        vector<bool>leftDiagonal(2*n-1,0);
        vector<bool>rightDiagonal(2*n-1,0);


        find(0,n,board,ans,col,leftDiagonal,rightDiagonal);

        return ans;

    }
};

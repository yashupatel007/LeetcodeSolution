class Solution {
public:
    int smallestBalancedIndex(vector<int>& nums) {
        int n=nums.size();
        long long max_sum=0;
        long long product=1;
        vector<long long>right_check(n,1);
        //calculate the sum
        for(int i=0;i<n;i++)
        {
            max_sum+=nums[i];
        }
        //store the right product
        for(int j=n-1;j>=0;j--)
        {
            right_check[j]=product;
            if(product>max_sum || nums[j]>max_sum/product)
                product=max_sum+1;
            else
                product*=nums[j];   
        }
        long long left_sum=0;
        for(int k=0;k<n;k++)
        {
             if(left_sum==right_check[k])
                return k;
            left_sum+=nums[k];
        }
        return -1;
    }
};

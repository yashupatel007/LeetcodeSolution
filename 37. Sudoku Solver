class Solution {
public:
    bool check(int n,vector<vector<char>>& board,int i,int j)
    {
        char c='0'+n;
        // check if num not present in row
        for(int col=0;col<9;col++)
        {
            if(board[i][col]==c)
                return 0;
        }
        // check if num not present in col
        for(int row=0;row<9;row++)
        {
            if(board[row][j]==c)
                return 0;;
        }
        // check if num not present in box(3*3)
        int row=(i/3)*3;
        int col=(j/3)*3;

        for(int a=0;a<3;a++)
        {
            for(int b=0;b<3;b++)
            {
                if(board[a+row][b+col]==c)
                    return 0;
            }
        }
        return 1;
    }
    bool find(int i,int j,vector<vector<char>>& board)
    {
        if(i==9)
            return 1;
        if(j==9)
            return find(i+1,0,board);
        
        if(board[i][j]!='.')
            return find(i,j+1,board);;

        for(int n=1;n<10;n++)
        {
            if(check(n,board,i,j))
            {
                board[i][j]='0'+n;
                if(find(i,j+1,board))
                    return 1;
                board[i][j]='.';
            }
        }
        return 0;
    }
    void solveSudoku(vector<vector<char>>& board) {
        find(0,0,board);
    }
};

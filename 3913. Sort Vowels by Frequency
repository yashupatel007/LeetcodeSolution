class Solution {
public:
    bool vowel(char v)
    {
        if(v=='a' || v=='e' || v=='i' || v=='o' || v=='u')
            return true;
        return false;
    }
    string sortVowels(string s) {
        unordered_map<char,int>mp_freq;
        unordered_map<char,int>f_index;
        vector<char>totalV;
        int index=0;

        for(int i=0;i<s.length();i++)
            {
                if(vowel(s[i]))
                {
                    mp_freq[s[i]]++;
                    totalV.push_back(s[i]);
                }
                if(f_index.find(s[i])==f_index.end())
                    f_index[s[i]]=i;
            }
        sort(totalV.begin(),totalV.end(),[&](char a , char b)
            {
            if(mp_freq[a] != mp_freq[b])
                return mp_freq[a] > mp_freq[b];
            return f_index[a]<f_index[b];
            });

        for(int i=0;i<s.length();i++)
            {
                if(vowel(s[i]))
                    s[i]=totalV[index++];
            }
        return s;
        
    }
};

class Solution {
public:
    long long minOperations(vector<int>& nums) {
        int n=nums.size();
        long long ans=0;
        int temp=n;
        for(int i=0;i<n-1;i++)
            {
                if(nums[i]>nums[i+1])
                {
                    ans+=(long long)(nums[i]-nums[i+1]);
                    // nums[i+1]=nums[i];
                }
            }
        return ans;
    }
};

class Solution {
public:
    bool canJump(vector<int>& nums) {
        int n=nums.size();
        int k=n-1;
        for(int i=n-1;i>=0;i--)
        {
            if(i+nums[i]>=k)//can we reach the start
            {
                k=i;//if yes update the k
            }
        }
        return k==0;
    }
};

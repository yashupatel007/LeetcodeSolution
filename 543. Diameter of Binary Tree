/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    int maxLen(TreeNode *node,int &maxdia)
    {
        if(node==NULL)//base case
            return 0;

        int left=maxLen(node->left,maxdia);//go left most 
        int right=maxLen(node->right,maxdia);//go right most
        
        maxdia=max(maxdia,left+right);//update maxdia
        return 1+max(left,right);//return 1+max to include edge of parent
    }
    int diameterOfBinaryTree(TreeNode* root) {
        int maxdia=0;
        maxLen(root,maxdia);
        return maxdia;
    }
};

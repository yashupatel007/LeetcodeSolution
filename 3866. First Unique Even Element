class Solution {
public:
    int firstUniqueEven(vector<int>& nums) {
        int n=nums.size();
        vector<int>check(101,0);
        int ans=-1;
        for(int i=0;i<n;i++)
        {
            check[nums[i]]++;
        }
        for(int j=0;j<n;j++)
        {
           if(nums[j]%2==0 && check[nums[j]]==1)
           {
            ans=nums[j];
            break;
           }
        }
    return ans;
    }
};

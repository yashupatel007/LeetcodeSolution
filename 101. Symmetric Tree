class Solution {
public:
    bool sameTree(TreeNode* r1,TreeNode* r2)
    {
        if(r1!=NULL && r2!=NULL)
        {
            if(r1->val!=r2->val)
                return false;
        }
        else
        {
            if(r1==r2)
                return true;
            return false;
        }
        return sameTree(r1->left,r2->right) && sameTree(r1->right,r2->left);
    }
    bool isSymmetric(TreeNode* root) {
        return sameTree(root->left,root->right);
    }
};

        ////2nd --- more efficient approach----
        int n=heights.size();
        int area=0;
        stack<int>st;
        for(int i=0;i<n;i++)
        {
            while(!st.empty() && heights[i]<heights[st.top()])
            {
                int index=st.top();
                st.pop();
                if(!st.empty())
                {
                    area=max(area,heights[index]*(i-st.top()-1));
                }
                else
                {
                    area=max(area,heights[index]*i);
                }
            }
            st.push(i);
        }
        while(!st.empty())
        {
            int index=st.top();
            st.pop();
            if(!st.empty())
                {
                    area=max(area,heights[index]*(n-st.top()-1));
                }
                else
                {
                    area=max(area,heights[index]*n);
                }
        }
        return area;
    }
